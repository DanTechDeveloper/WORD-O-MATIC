{
  "$schema": "https://opencode.ai/config.json",

  "instructions": [],

  "references": {
    "docs": {
      "path": "my-app/docs",
      "description": "Project documentation: architecture, conventions, database, deployment, gameplay, gamification, modules, reports, rules, developer guide"
    }
  },
  "plugin": [
    "opencode-history-search",
    "opencode-web-fetch",
    "opencode-notifier",
    "opencode-wakatime",
    "@dietrichgebert/ponytail"
  ],

  "permission": {
    "edit": "ask",

    "webfetch": "allow",

    "bash": {
      "*": "ask",

      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",

      "composer *": "allow",
      "npm *": "allow",
      "bun *": "allow",

      "php artisan route:list": "allow",
      "php artisan test": "allow",

      "php artisan migrate*": "ask",
      "php artisan db:*": "ask",

      "git commit *": "ask",
      "git push *": "ask"
    }
  }
}