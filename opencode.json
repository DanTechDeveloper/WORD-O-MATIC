{
  "$schema": "https://opencode.ai/config.json",

  "instructions": [
    "my-app/docs/RULES.md",
    "my-app/docs/AGENTS.md"
  ],
  "plugin": [
    "opencode-history-search",
    "opencode-web-fetch",
    "opencode-notifier",
    "opencode-wakatime"
  ],

  "permission": {
    "edit": "ask",

    "webfetch": "allow",

    "bash": {
      "*": "ask",

      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",

      "composer *": "allow",
      "npm *": "allow",
      "bun *": "allow",

      "php artisan route:list": "allow",
      "php artisan test": "allow",

      "php artisan migrate*": "ask",
      "php artisan db:*": "ask",

      "git commit *": "ask",
      "git push *": "ask"
    }
  }
}